@page
@model WebApplication1.Pages.Records.CleanIndexModel
@{
    ViewData["Title"] = "綠色商店清單 (Clean)";
}

<h1>綠色商店清單 (資料庫版)</h1>

<div class="card mb-3">
    <div class="card-body">
        <form method="get" class="row g-3">
            <div class="col-md-3">
                <label class="form-label">類別代碼（Category）</label>
                <input class="form-control" name="Category" value="@Model.Category" placeholder="例如：1" />
            </div>
            <div class="col-md-3">
                <label class="form-label">店鋪代碼（Store Code）</label>
                <input class="form-control" name="StoreCode" value="@Model.StoreCode" placeholder="例如：L000686" />
            </div>
            <div class="col-md-3">
                <label class="form-label">店鋪名稱（模糊搜尋）</label>
                <input class="form-control" name="StoreName" value="@Model.StoreName" placeholder="例如：大同、7-11" />
            </div>
            <div class="col-md-3 align-self-end">
                <div class="form-check form-switch mb-2">
                    <input class="form-check-input" type="checkbox" id="OnlyDistinct" name="OnlyDistinct" value="true" @(Model.OnlyDistinct ? "checked" : "") />
                    <label class="form-check-label" for="OnlyDistinct">只顯示每店一筆</label>
                </div>
            </div>

            <div class="col-12">
                <div class="btn-group" role="group">
                    <button class="btn btn-primary" type="submit">查詢</button>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="alert alert-info">
    合計店鋪筆數：<strong>@Model.TotalCount</strong> ，去重後總店鋪數：<strong>@Model.DistinctStoresCount</strong>
</div>

<div class="table-responsive mt-2">
    <table class="table table-striped table-bordered table-sm">
        <thead class="table-dark">
            <tr>
                <th>Id</th>
                <th>類別代碼</th>
                <th>標誌編號</th>
                <th>店鋪代碼 (StoreNo)</th>
                <th>店鋪名稱</th>
                <th>負責人</th>
                <th>店鋪地址</th>
                <th>聯絡電話</th>
                <th>統一編號</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Items != null && Model.Items.Any())
            {
                @foreach (var r in Model.Items)
                {
                    <tr>
                        <td>@r.Id</td>
                        <td>@r.ClassType</td>
                        <td>@r.FlagNo</td>
                        <td>@r.StoreNo</td>
                        <td>@r.StoreName</td>
                        <td>@r.Undertaker</td>
                        <td>@r.StoreAddr</td>
                        <td>@r.ContactTel</td>
                        <td>@r.TaxNo</td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="9" class="text-center text-muted py-3">查無符合條件的店家資料。</td>
                </tr>
            }
        </tbody>
    </table>
</div>